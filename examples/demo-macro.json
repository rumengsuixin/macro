{
    "name": "demo-books",
    "version": 1,
    "steps": [
        {
            "type": "goto",
            "url": "https://books.toscrape.com/"
        },
        {
            "type": "waitForSelector",
            "selector": ".product_pod"
        }
    ],
    "extract": {
        "mode": "list",
        "listSelector": ".product_pod",
        "fields": [
            {
                "name": "title",
                "selector": "h3 a",
                "type": "attr",
                "attr": "title"
            },
            {
                "name": "price",
                "selector": ".price_color",
                "type": "text"
            },
            {
                "name": "link",
                "selector": "h3 a",
                "type": "attr",
                "attr": "href"
            }
        ]
    }
}
